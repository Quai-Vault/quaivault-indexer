# E2E Test Configuration
# Copy to .env.e2e and fill in values
#
# Prerequisites before running E2E tests:
# 1. Indexer running: SUPABASE_SCHEMA=dev npm run dev
# 2. Dev schema created: Run SELECT create_network_schema('dev'); in Supabase
# 3. Contracts deployed: Deploy all contracts to Orchard testnet
# 4. Test wallets funded: Each private key needs testnet QUAI for gas

# =============================================================================
# Quai Network Configuration
# =============================================================================

# Quai Network RPC (Orchard Testnet)
# Use base URL without shard path - the SDK uses usePathing: true
QUAI_RPC_URL=https://rpc.orchard.quai.network
QUAI_WS_URL=wss://rpc.orchard.quai.network
QUAI_CHAIN_ID=9000

# =============================================================================
# Test Wallet Private Keys
# =============================================================================
#
# SECURITY WARNING: These keys should ONLY be used for testing!
# Never use keys with real mainnet funds.
#
# Minimum 3 owners for multisig threshold testing
# Minimum 2 guardians for social recovery testing

OWNER_PRIVATE_KEY_1=0x...
OWNER_PRIVATE_KEY_2=0x...
OWNER_PRIVATE_KEY_3=0x...

GUARDIAN_PRIVATE_KEY_1=0x...
GUARDIAN_PRIVATE_KEY_2=0x...

# =============================================================================
# Deployed Contract Addresses
# =============================================================================
#
# These should match the addresses used by the running indexer

# Required Contracts
QUAIVAULT_FACTORY_ADDRESS=0x...
QUAIVAULT_IMPLEMENTATION_ADDRESS=0x...

# Optional Module Contracts (tests will be skipped if not configured)
DAILY_LIMIT_MODULE_ADDRESS=0x...
WHITELIST_MODULE_ADDRESS=0x...
SOCIAL_RECOVERY_MODULE_ADDRESS=0x...
MULTISEND_ADDRESS=0x...

# =============================================================================
# Supabase Configuration
# =============================================================================
#
# Uses the same Supabase instance as the indexer
# Recommended: Use 'dev' schema for E2E tests to avoid impacting production data

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_SCHEMA=dev

# =============================================================================
# Indexer Configuration
# =============================================================================

# Indexer health check endpoint port
HEALTH_CHECK_PORT=3000

# =============================================================================
# Timing Configuration (milliseconds)
# =============================================================================

# How often to poll indexer for expected database changes
INDEXER_POLL_INTERVAL=15000

# Maximum time to wait for transaction confirmation and indexing
TX_CONFIRMATION_TIMEOUT=60000

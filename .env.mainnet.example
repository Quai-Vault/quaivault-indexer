# QuaiVault Indexer - Mainnet Configuration
# Copy this file to .env and fill in your values

# ============================================
# QUAI NETWORK (Mainnet)
# Use base URL without shard path - the SDK uses usePathing: true
# ============================================
QUAI_RPC_URL=https://rpc.quai.network
QUAI_WS_URL=wss://rpc.quai.network

# ============================================
# SUPABASE
# ============================================
# Get these from your Supabase project settings
# Option 1: Use same project with different schema (recommended)
# Option 2: Use separate Supabase project for complete isolation
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Database schema for multi-network support
# Use 'mainnet' for mainnet data (separate from testnet)
# First run: SELECT create_network_schema('mainnet'); in Supabase SQL Editor
SUPABASE_SCHEMA=mainnet

# ============================================
# CONTRACT ADDRESSES (Mainnet)
# ============================================
# Required: Core contracts
QUAIVAULT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
QUAIVAULT_IMPLEMENTATION_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: Module and utility contracts (leave empty if not deployed)
DAILY_LIMIT_MODULE_ADDRESS=
WHITELIST_MODULE_ADDRESS=
SOCIAL_RECOVERY_MODULE_ADDRESS=
MULTISEND_ADDRESS=

# ============================================
# INDEXER SETTINGS
# ============================================
# Block number to start indexing from (use deployment block of ProxyFactory)
START_BLOCK=0

# Number of blocks to process per batch during backfill
BATCH_SIZE=1000

# Milliseconds between poll cycles for new blocks
POLL_INTERVAL=5000

# Number of block confirmations before indexing (for reorg safety)
# Mainnet may want higher confirmations for safety
CONFIRMATIONS=3

# ============================================
# HEALTH CHECK
# ============================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=3002

# Alert if indexer falls this many blocks behind (ignored during sync)
HEALTH_MAX_BLOCKS_BEHIND=100

# ============================================
# RATE LIMITING (Advanced)
# ============================================
# Maximum RPC requests per time window (default: 50)
# RATE_LIMIT_REQUESTS=50

# Time window in milliseconds (default: 1000 = 1 second)
# RATE_LIMIT_WINDOW_MS=1000

# ============================================
# CACHING (Advanced)
# ============================================
# Maximum number of block timestamps to cache (default: 1000)
# TIMESTAMP_CACHE_SIZE=1000

# ============================================
# RPC TIMEOUT (Advanced)
# ============================================
# Timeout for individual RPC calls in milliseconds (default: 30000 = 30 seconds)
# RPC_CALL_TIMEOUT_MS=30000

# ============================================
# CIRCUIT BREAKER (Advanced)
# ============================================
# Consecutive poll failures before pausing operations (default: 10)
# CB_FAILURE_THRESHOLD=10

# Cooldown in milliseconds before retrying after circuit opens (default: 60000)
# CB_COOLDOWN_MS=60000

# ============================================
# HEALTH RATE LIMITING (Advanced)
# ============================================
# HEALTH_RATE_LIMIT_WINDOW_MS=60000   # Rate limit window in ms (default: 60000)
# HEALTH_RATE_LIMIT_MAX=60            # Max requests per window (default: 60)
# HEALTH_RATE_LIMIT_MAX_IPS=10000     # Max tracked IPs (default: 10000)
# HEALTH_RATE_LIMIT_CLEANUP_MS=300000 # Stale IP cleanup interval (default: 300000)

# ============================================
# INDEXER ADVANCED
# ============================================
# Max addresses per getLogs RPC call (default: 100)
# GET_LOGS_CHUNK_SIZE=100

# Log warning when tracked wallets exceed this (default: 500000)
# WALLET_WARNING_THRESHOLD=500000

# ============================================
# RETRY SETTINGS (Advanced)
# ============================================
# Maximum consecutive failures before logging error and resetting (default: 5)
# RETRY_MAX_RETRIES=5

# Initial retry delay in milliseconds (default: 1000 = 1 second)
# RETRY_BASE_DELAY_MS=1000

# Maximum retry delay cap in milliseconds (default: 60000 = 1 minute)
# RETRY_MAX_DELAY_MS=60000

# Number of consecutive failures before escalating to error log level (default: 3)
# RETRY_ERROR_THRESHOLD=3

# QuaiVault Indexer Configuration
# Copy this file to .env and fill in your values

# ============================================
# QUAI NETWORK
# Use base URL without shard path - the SDK uses usePathing: true
# ============================================
QUAI_RPC_URL=https://rpc.orchard.quai.network
QUAI_WS_URL=wss://rpc.orchard.quai.network

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Database schema for multi-network support
# Use 'dev' for development, 'testnet' or 'mainnet' for production
SUPABASE_SCHEMA=dev

# ============================================
# CONTRACT ADDRESSES
# ============================================
# Required: Core contracts
QUAIVAULT_FACTORY_ADDRESS=0x...
QUAIVAULT_IMPLEMENTATION_ADDRESS=0x...

# Optional: Module and utility contracts (leave empty if not deployed)
DAILY_LIMIT_MODULE_ADDRESS=
WHITELIST_MODULE_ADDRESS=
SOCIAL_RECOVERY_MODULE_ADDRESS=
MULTISEND_ADDRESS=

# ============================================
# INDEXER SETTINGS
# ============================================
BATCH_SIZE=1000
POLL_INTERVAL=5000
START_BLOCK=0
CONFIRMATIONS=2

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info              # debug, info, warn, error
LOG_TO_FILE=false           # Enable file logging with rotation (logs/*.log)
NODE_ENV=development        # development = pretty console, production = JSON

# ============================================
# HEALTH CHECK
# ============================================
HEALTH_CHECK_ENABLED=true   # Enable health check HTTP server
HEALTH_CHECK_PORT=3000      # Port for health check endpoints
HEALTH_MAX_BLOCKS_BEHIND=100 # Max blocks behind before reporting unhealthy

# ============================================
# RPC TIMEOUT (Advanced)
# ============================================
# RPC_CALL_TIMEOUT_MS=30000 # Timeout for individual RPC calls in ms (default: 30000)

# ============================================
# CIRCUIT BREAKER (Advanced)
# ============================================
# CB_FAILURE_THRESHOLD=10   # Consecutive failures before pausing (default: 10)
# CB_COOLDOWN_MS=60000      # Cooldown before retrying after circuit opens (default: 60000)

# ============================================
# HEALTH RATE LIMITING (Advanced)
# ============================================
# HEALTH_RATE_LIMIT_WINDOW_MS=60000   # Rate limit window in ms (default: 60000)
# HEALTH_RATE_LIMIT_MAX=60            # Max requests per window (default: 60)
# HEALTH_RATE_LIMIT_MAX_IPS=10000     # Max tracked IPs (default: 10000)
# HEALTH_RATE_LIMIT_CLEANUP_MS=300000 # Stale IP cleanup interval (default: 300000)

# ============================================
# INDEXER ADVANCED
# ============================================
# GET_LOGS_CHUNK_SIZE=100    # Max addresses per getLogs call (default: 100)
# WALLET_WARNING_THRESHOLD=500000  # Log warning when tracked wallets exceed this (default: 500000)

# ============================================
# RETRY SETTINGS (Advanced)
# ============================================
# RETRY_MAX_RETRIES=5       # Max consecutive failures before reset (default: 5)
# RETRY_BASE_DELAY_MS=1000  # Initial retry delay in ms (default: 1000)
# RETRY_MAX_DELAY_MS=60000  # Max retry delay cap in ms (default: 60000)
# RETRY_ERROR_THRESHOLD=3   # Failures before error log level (default: 3)
